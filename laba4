С клавиатуры вводится два числа K и N. Квадратная матрица А(N,N), состоящая из 4-х равных по размерам подматриц, B,C,D,E заполняется случайным образом целыми числами в интервале [-10,10]. Для отладки использовать не случайное заполнение, а целенаправленное.

8.	Формируется матрица F следующим образом: скопировать в нее А и если в С количество простых чисел в нечетных столбцах, чем количество нулевых  элементов в четных строках, то поменять местами Е и С симметрично, иначе С и В поменять местами несимметрично. При этом матрица А не меняется. После чего если определитель матрицы А больше суммы диагональных элементов матрицы F, то вычисляется выражение: A-1*AT – K * F, иначе вычисляется выражение (AТ +G-1-F-1)*K, где G-нижняя треугольная матрица, полученная из А. Выводятся по мере формирования А, F и все матричные операции последовательно.

import numpy as np
import matplotlib.pyplot as plt


def is_prime(x):
    x = abs(int(x))

    if x < 2:
        return False

    for i in range(2, int(x ** 0.5) + 1):
        if x % i == 0:
            return False

    return True


def load_matrix_from_file(N):
    A = np.loadtxt("matrix_data.txt", dtype=int)

    if A.shape != (N, N):
        print("Ошибка: размер матрицы в файле не совпадает с N")
        exit()

    if N % 2 != 0:
        print("Ошибка: N должно быть чётным")
        exit()

    return A


def split_blocks(A):
    h = A.shape[0] // 2

    E = A[:h, :h]
    B = A[:h, h:]
    D = A[h:, :h]
    C = A[h:, h:]

    return E, B, D, C


def build_F(A):
    F = A.copy()

    E, B, D, C = split_blocks(A)
    h = A.shape[0] // 2

    prime_count = 0

    for j in range(1, h, 2):
        for i in range(h):
            if is_prime(C[i][j]):
                prime_count += 1

    zero_count = 0

    for i in range(0, A.shape[0], 2):
        for j in range(A.shape[1]):
            if A[i][j] == 0:
                zero_count += 1

    print("\nКоличество простых чисел в нечётных столбцах C:", prime_count)
    print("Количество нулевых элементов в чётных строках A:", zero_count)

    if prime_count > zero_count:
        F[:h, h:] = C.copy()
        F[h:, h:] = B.copy()

        print("\nУсловие выполнено: C и B поменяны местами несимметрично")
    else:
        F[:h, :h] = C.copy()
        F[h:, h:] = E.copy()

        print("\nУсловие не выполнено: C и E поменяны местами симметрично")

    return F


def compute_result(A, F, K):
    det_A = np.linalg.det(A)
    sum_diag_F = np.trace(F)

    print("\nОпределитель матрицы A:", round(det_A, 3))
    print("Сумма диагональных элементов матрицы F:", sum_diag_F)

    G = np.tril(A)

    try:
        if det_A > sum_diag_F:
            print("\nВычисляется выражение: A^(-1) * A^T - K * F^(-1)")
            result = np.linalg.inv(A) @ A.T - K * np.linalg.inv(F)
        else:
            print("\nВычисляется выражение: (A^T + G^(-1) - F^(-1)) * K")
            result = (A.T + np.linalg.inv(G) - np.linalg.inv(F)) * K

        return result

    except np.linalg.LinAlgError:
        return "Ошибка: одна из матриц необратима, невозможно найти обратную матрицу"


def plot_graphs(F):
    plt.figure(figsize=(15, 4))

    plt.subplot(1, 3, 1)
    plt.plot(F.sum(axis=1), marker='o')
    plt.title("Сумма элементов по строкам F")
    plt.xlabel("Номер строки")
    plt.ylabel("Сумма")
    plt.grid(True)

    plt.subplot(1, 3, 2)
    plt.bar(range(F.shape[1]), F.mean(axis=0))
    plt.title("Среднее значение по столбцам F")
    plt.xlabel("Номер столбца")
    plt.ylabel("Среднее")
    plt.grid(True)

    plt.subplot(1, 3, 3)
    plt.hist(F.flatten(), bins=10)
    plt.title("Гистограмма значений F")
    plt.xlabel("Значения")
    plt.ylabel("Количество")
    plt.grid(True)

    plt.tight_layout()
    plt.show()


def main():
    K = int(input("Введите K: "))
    N = int(input("Введите N: "))

    if N % 2 != 0:
        print("Ошибка: N должно быть чётным, так как матрица делится на 4 равные подматрицы")
        exit()

    A = load_matrix_from_file(N)

    print("\nМатрица A:")
    print(A)

    E, B, D, C = split_blocks(A)

    print("\nПодматрица E:")
    print(E)

    print("\nПодматрица B:")
    print(B)

    print("\nПодматрица D:")
    print(D)

    print("\nПодматрица C:")
    print(C)

    F = build_F(A)

    print("\nМатрица F:")
    print(F)

    result = compute_result(A, F, K)

    print("\nРезультат вычисления выражения:")
    print(result)

    plot_graphs(F)


if __name__ == "__main__":
    main()
