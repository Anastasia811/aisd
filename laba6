def brute_force_method(N, K, ratings, max_total_cost):
    best_value = -1
    best_combinations = []
    checked = 0

    for combo in product(range(1, 4), repeat=N):
        checked += 1
        if sum(combo) == K:
            total_cost = sum(combo[i] * ratings[i][1] for i in range(N))
            total_value = sum(combo[i] * ratings[i][0] for i in range(N))
            if total_cost <= max_total_cost:
                if total_value > best_value:
                    best_value = total_value
                    best_combinations = [combo]
                elif total_value == best_value:
                    best_combinations.append(combo)

    return best_combinations, best_value, checked

def optimized_method(N, K, ratings, max_total_cost):
    best_value = -1
    best_combinations = []
    checked = 0

    max_values = [max(ratings[i][0], ratings[i][0] * 2, ratings[i][0] * 3) for i in range(N)]

    def generate(current, current_sum, current_cost, current_value, index):
        nonlocal best_value, best_combinations, checked

        if current_cost > max_total_cost:
            return

        if index == N:
            checked += 1
            if current_sum == K:
                if current_value > best_value:
                    best_value = current_value
                    best_combinations = [tuple(current)]
                elif current_value == best_value:
                    best_combinations.append(tuple(current))
            return

        min_possible = current_sum + (N - index)
        max_possible = current_sum + 3 * (N - index)

        if min_possible > K or max_possible < K:
            return

        upper_bound = current_value + sum(max_values[index:])
        if upper_bound < best_value:
            return

        for x in range(1, 4):
            if current_sum + x + (N - index - 1) <= K <= current_sum + x + 3 * (N - index - 1):
                generate(
                    current + [x],
                    current_sum + x,
                    current_cost + x * ratings[index][1],
                    current_value + x * ratings[index][0],
                    index + 1
                )

    generate([], 0, 0, 0, 0)
    return best_combinations, best_value, checked

ratings = [(8, 3), (6, 2), (7, 4), (5, 2), (9, 5)]
