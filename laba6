1 часть – написать программу в соответствии со своим вариантом задания. Написать 2 варианта формирования (алгоритмический и с помощью функций Питона), сравнив по времени их выполнение.
2 часть – усложнить написанную программу, введя по своему усмотрению в условие минимум одно ограничение на характеристики объектов (которое будет сокращать количество переборов)  и целевую функцию для нахождения оптимального  решения.

В парламентскую комиссию нужно выбрать К членов. Претендентов предоставили N партий. Вывести все возможные варианты комиссии (от каждой партии должно быть от 1 до 3 членов).
import timeit
from itertools import product

def algorithmic_method(N, K):

    result = []

    def generate(current, current_sum, index):

        if index == N:

            if current_sum == K:
                result.append(tuple(current))
            return

        for x in range(1, 4):
            if current_sum + x + (N - index - 1) <= K <= current_sum + x + 3 * (N - index - 1):
                generate(current + [x], current_sum + x, index + 1)

    generate([], 0, 0)
    return result

def python_method(N, K):
    return [combo for combo in product(range(1, 4), repeat=N) if sum(combo) == K]

N, K = 5, 8

print(" Алгоритмический метод ")
algo_result = algorithmic_method(N, K)

for idx, combo in enumerate(algo_result, 1):

    print(f"{idx}) {combo}")

print(f"\nВсего возможных комбинаций: {len(algo_result)}")
print("\nМетод с itertools ")
py_result = python_method(N, K)

for idx, combo in enumerate(py_result, 1):
    print(f"{idx}) {combo}")

print(f"\nВсего возможных комбинаций: {len(py_result)}")

algo_time = timeit.timeit(lambda: algorithmic_method(N, K), number=1000)
py_time = timeit.timeit(lambda: python_method(N, K), number=1000)

print("\nСравнение скорости выполнения:")
print(f"Алгоритмический: {algo_time:.5f}")
print(f"itertools: {py_time:.5f}")

if algo_time < py_time:
    print("Метод algorithmic_method быстрее")

elif py_time < algo_time:
    print("Метод python_method быстрее")

else:
    print("Методы работают одинаково быстро")

def optimized_method(N, K, ratings):
    best_value = -1
    best_combinations = []
    for combo in product(range(1, 4), repeat=N):
        if sum(combo) == K and sum(1 for x in combo if x == 3) <= 2:
            total_value = sum(combo[i] * ratings[i] for i in range(N))
            if total_value > best_value:
                best_value = total_value
                best_combinations = [combo]
            
            elif total_value == best_value:
                best_combinations.append(combo)

    return best_combinations, best_value

ratings = [8, 6, 7, 5, 9]

print("\nОптимизация: не более 2 партий могут дать по 3 человека")

print("Целевая функция: максимизировать общий рейтинг комиссии")

print("Рейтинг 1 человека по партиям:")

for i, value in enumerate(ratings, 1):
    print(f"Партия {i}: {value}")

opt_result, opt_value = optimized_method(N, K, ratings)
print(f"\nЛучшее значение целевой функции: {opt_value}")
print("Оптимальные варианты:")

