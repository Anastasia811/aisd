1 часть – написать программу в соответствии со своим вариантом задания. Написать 2 варианта формирования (алгоритмический и с помощью функций Питона), сравнив по времени их выполнение.
2 часть – усложнить написанную программу, введя по своему усмотрению в условие минимум одно ограничение на характеристики объектов (которое будет сокращать количество переборов)  и целевую функцию для нахождения оптимального  решения.

В парламентскую комиссию нужно выбрать К членов. Претендентов предоставили N партий. Вывести все возможные варианты комиссии (от каждой партии должно быть от 1 до 3 членов).
import timeit
from itertools import product

def algorithmic_method(N, K):
    result = []

    def generate(current, current_sum, index):
        if index == N:
            if current_sum == K:
                result.append(tuple(current))
            return
        for x in range(1, 4):
            if current_sum + x + (N - index - 1) <= K <= current_sum + x + 3 * (N - index - 1):
                generate(current + [x], current_sum + x, index + 1)

    generate([], 0, 0)
    return result

def python_method(N, K):
    return [combo for combo in product(range(1, 4), repeat=N) if sum(combo) == K]

N, K = 5, 8

