def multiplication (a, b):
    n, m, p = len(a), len(b[0]), len(b)
    return [[sum(a[i][k]*b[k][j] for k in range (p)) for j in range (m)] for i in range (n)]
def transposition (a):
    n = len(a)
    return [[a[j][i] for j in range (n)] for i in range (n)]
def s_mul (k, a):
    return [[k * x for x in row] for row in a]
k = int(input('k: '))
n = int(input('n: '))

file_matrix = read_matrix('matrix.txt')
a = extract_matrix(file_matrix, n)
print_matrix(a, 'matrix a')

f = copy.deepcopy(a)
nulls = conclusion1(f, n)
summ_pos = conclusion2(f, n)
print(f'\n Строк с одними нулями в четных столбцах в области 2: {nulls}')
print(f'\n Сумма положительных элементов в четных строках в области 4: {summ_pos}')
if nulls > summ_pos:
    swap_areas1(f, n)
    swap_info = 'Симметричный обмен областей 1 и 2:'
else:
    swap_areas2(f, n)
    swap_info = 'Несимметричный обмен областей 2 и 3:'
print_matrix(f, 'matrix f')
print(f'\n {swap_info}')

kf = s_mul(k, f)
kf_a = multiplication(kf, a)
print_matrix(kf_a, 'k*f*a')

at = transposition(a)
k_at = s_mul(k, at)
print_matrix(k_at, 'k*a^t')

result = [[kf_a[i][j] - k_at[i][j] for j in range (n)] for i in range (n)]
print_matrix(result, '(k*f)*a - k*a^t')
